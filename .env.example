# ═══════════════════════════════════════════════════════════════════════════════
# MCP Server 環境變數設定範本
# ═══════════════════════════════════════════════════════════════════════════════
# 複製此檔案為 .env 並填入實際值

# ─────────────────────────────────────────────────────────────────────────────
# API Key 認證 (JSON 陣列格式)
# ─────────────────────────────────────────────────────────────────────────────
# 格式說明：
# MCP_API_KEYS 為 JSON 陣列
# 每組包含：api_key (required), tools (optional), gmail_account (optional)
# tools: ["*"] 表示允許所有 tools，或指定 ["tool1", "tool2", ...]
# gmail_account: 綁定 Gmail 帳號（需在 gmail_accounts.json 設定）
MCP_API_KEYS=[{"api_key": "sk-YOUR-API-KEY-HERE", "tools": ["*"]}]

# ─────────────────────────────────────────────────────────────────────────────
# 伺服器設定
# ─────────────────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=30786

# ─────────────────────────────────────────────────────────────────────────────
# Python 執行環境
# ─────────────────────────────────────────────────────────────────────────────
PYTHON_WORK_DIR=./workspace

# ─────────────────────────────────────────────────────────────────────────────
# 執行限制
# ─────────────────────────────────────────────────────────────────────────────
MCP_EXEC_TIMEOUT=300
MCP_MAX_INPUT=1000000
MCP_MAX_OUTPUT=1000000

# ─────────────────────────────────────────────────────────────────────────────
# TMDB API (電影資料庫)
# ─────────────────────────────────────────────────────────────────────────────
# 申請網址: https://www.themoviedb.org/settings/api
TMDB_API_KEY=YOUR_TMDB_API_KEY

# ─────────────────────────────────────────────────────────────────────────────
# MySQL 資料庫
# ─────────────────────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_database_name
MYSQL_MAX_ROWS=10000

# ─────────────────────────────────────────────────────────────────────────────
# Gmail API
# ─────────────────────────────────────────────────────────────────────────────
# 路徑指向 gmail_accounts.json（需自行建立）
# 格式請參考 Gmail API 文件
GMAIL_ACCOUNTS_PATH=./gmail_accounts.json

# ─────────────────────────────────────────────────────────────────────────────
# Playwright Web Automation
# ─────────────────────────────────────────────────────────────────────────────
PLAYWRIGHT_CDP_ENDPOINT=http://127.0.0.1:9222

# ─────────────────────────────────────────────────────────────────────────────
# Ollama Web API (選用)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_API_KEY=YOUR_OLLAMA_API_KEY

# ─────────────────────────────────────────────────────────────────────────────
# Gemini API (選用)
# ─────────────────────────────────────────────────────────────────────────────
# JSON 陣列格式，可設定多組 Key
GEMINI_API_KEYS=[{"api_key": "YOUR_GEMINI_API_KEY"}]

# ─────────────────────────────────────────────────────────────────────────────
# DeepSeek API (選用)
# ─────────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
